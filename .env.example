# WatchTower Environment Variables
# Copy this file to .env.local and fill in your values.

NEXT_PUBLIC_SITE_URL=https://watchtower.xyz

# =============================================================================
# REQUIRED: Smart Contract Deployment (X Layer Mainnet)
# =============================================================================
# Private key for the wallet that deploys and writes to WatchTowerRegistry.
# This wallet needs OKB for gas. NEVER commit a real private key.
PRIVATE_KEY=your_private_key_here

# =============================================================================
# OPTIONAL: API Keys (improves scan accuracy)
# =============================================================================
# Ethplorer API key — used by Whale Intelligence module for top holder data.
# Register a FREE personal key at https://ethplorer.io/wallet for 10 req/sec.
# Falls back to 'freekey' (2 req/sec) if not set.
ETHPLORER_API_KEY=

# LunarCrush key placeholder for the production social provider.
LUNARCRUSH_API_KEY=

# =============================================================================
# OPTIONAL: Smart Contract Configuration
# =============================================================================
# Deployed WatchTowerRegistry address on X Layer.
# NEXT_PUBLIC_ is used by both the server and the verifier UI.
NEXT_PUBLIC_REGISTRY_ADDRESS=
NEXT_PUBLIC_REGISTRY_CHAIN_ID=196
NEXT_PUBLIC_REGISTRY_RPC_URL=
XLAYER_RPC_URL=

# Optional chain auto-detection RPC overrides.
# Public defaults are provided for development; paid providers are recommended in production.
ETHEREUM_RPC_URL=
BSC_RPC_URL=
POLYGON_RPC_URL=
BASE_RPC_URL=
ARBITRUM_RPC_URL=
OPTIMISM_RPC_URL=
AVALANCHE_RPC_URL=
XLAYER_TESTNET_RPC_URL=

# Whether to record firewall-tier (0.5 USDT) scans on-chain.
# Set to 'false' to save gas and only record deep scans.
# Mainnet-safe default: false. Enable only after approving registry-write volume and gas budget.
RECORD_FIREWALL_SCANS=false

# =============================================================================
# SELF-HOSTED x402 PAYMENT VERIFICATION
# =============================================================================
# WatchTower returns HTTP 402 with a PAYMENT-REQUIRED challenge. Agents transfer
# USDT to the treasury on the configured network, then retry with:
#   Authorization: L402 <settlement_transaction_hash>
#
# Select the active production network explicitly. Mainnet values below are the
# release profile; testnet values remain available for isolated QA only.
NEXT_PUBLIC_NETWORK_ENV=mainnet

# Optional minimum block confirmations before a settlement transaction is accepted.
# Mainnet policy: wait for at least two confirmations before accepting settlement.
PAYMENT_MIN_CONFIRMATIONS=2

# Development profile. This is used only when NEXT_PUBLIC_NETWORK_ENV=development.
DEV_NETWORK_NAME=X Layer Testnet
DEV_CHAIN_ID=1952
DEV_RPC_URL=
DEV_TREASURY_ADDRESS=
DEV_PAYMENT_TOKEN_SYMBOL=USDT
DEV_USDT_ADDRESS=
DEV_PAYMENT_TOKEN_DECIMALS=6

# Optional non-production test profile.
TESTNET_NETWORK_NAME=X Layer Testnet
TESTNET_CHAIN_ID=1952
TESTNET_RPC_URL=
TESTNET_TREASURY_ADDRESS=
TESTNET_PAYMENT_TOKEN_SYMBOL=USDT
TESTNET_USDT_ADDRESS=
TESTNET_PAYMENT_TOKEN_DECIMALS=6

# Production/mainnet profile.
MAINNET_NETWORK_NAME="X Layer Mainnet"
MAINNET_CHAIN_ID=196
MAINNET_RPC_URL=
MAINNET_TREASURY_ADDRESS=
MAINNET_PAYMENT_TOKEN_SYMBOL=USDT0
MAINNET_USDT_ADDRESS=
MAINNET_PAYMENT_TOKEN_DECIMALS=6

# Backward-compatible aliases used as fallbacks by src/config/network.ts.
X402_PAY_TO=
X402_TOKEN_ADDRESS=

# Optional live payment regression test input for npm run test:payments.
# Must be a successful ERC-20 transfer to the configured treasury for >= 0.5 USDT.
PAYMENT_TEST_TX_HASH=

# Autonomous agent demos and SDK integrations.
# This wallet signs x402 payment transfers and needs both the configured ERC-20
# payment token and native gas on the active payment network.
AGENT_PAYMENT_KEY=

# =============================================================================
# DATABASE
# =============================================================================
# WatchTower uses environment-aware database switching:
#   - If TURSO_DATABASE_URL is set → connects to Turso (production/staging)
#   - If not set → uses local ./watchtower.db file (development)
#
# Local development requires NO configuration. SQLite is auto-created.
#
# For production, create a Turso database:
#   1. Install CLI: curl -sSfL https://get.tur.so/install.sh | bash
#   2. Sign up:     turso auth signup
#   3. Create DB:   turso db create watchtower
#   4. Get URL:     turso db show watchtower --url
#   5. Get token:   turso db tokens create watchtower
#   6. Push schema: npx drizzle-kit push
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# =============================================================================
# MCP Server
# =============================================================================
# Base URL for the WatchTower API. The MCP server and demo scripts use this.
# Defaults to http://localhost:3000 if not set.
WATCHTOWER_API_URL=http://localhost:3000
