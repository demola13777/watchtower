# ──────────────────────────────────────────────────────────────
# Watch Tower Demo Agent — Environment Configuration
# ──────────────────────────────────────────────────────────────

# Watch Tower MCP endpoint (local dev server)
WATCHTOWER_MCP_URL=http://localhost:3000/api/mcp

# LLM Provider: openrouter | openai | anthropic
LLM_PROVIDER=openrouter

# OpenRouter (default — free models available)
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# OpenAI (optional)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Anthropic (optional)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
